---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	/** About page: single “Last updated on …” line like the starter screenshot */
	variant?: 'article' | 'about';
};

const {
	variant = 'article',
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
} = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 560px;
				margin: 0 auto;
			}
			article {
				display: flex;
				flex-direction: column;
				align-items: stretch;
			}
			.hero-image {
				width: 100%;
				margin: 0 0 1.25rem 0;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: auto;
				margin: 0;
				border-radius: 0;
				box-shadow: none;
			}
			.prose {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
				color: var(--text);
				text-align: left;
			}
			.title {
				margin: 0 0 1.35rem 0;
				padding: 0;
				text-align: left;
				line-height: 1.3;
			}
			.title h1 {
				margin: 0 0 1rem 0;
				font-size: 30px;
				font-weight: 700;
				line-height: 1.18;
				color: var(--text);
			}
			.date {
				margin: 0 0 1.25rem 0;
				font-size: 13px;
				line-height: 1.5;
				color: var(--muted);
				font-weight: 400;
			}
			.title hr {
				margin: 0;
				border: none;
				border-top: 1px solid #e5e5e5;
			}
			.last-updated-on {
				font-style: normal;
			}
			.back-link {
				display: inline-block;
				margin: 0 0 1.8rem;
				color: var(--accent);
			}
			.prose :global(p) {
				margin: 0 0 1rem;
				font-size: 16px;
				line-height: 1.55;
			}
			.prose :global(h2) {
				margin: 1.25rem 0 0.25rem;
				font-size: 16px;
				line-height: 1.35;
			}
			.prose :global(.code-block) {
				position: relative;
				display: block;
				width: 100%;
				margin: 0 0 1.35rem;
			}
			.prose :global(.code-block pre) {
				margin: 0;
				padding-top: 2.75rem;
				padding-right: 1rem;
			}
			.prose :global(.copy-code) {
				position: absolute;
				top: 0.65rem;
				right: 0.65rem;
				z-index: 1;
				border: 1px solid var(--code-block-border);
				border-radius: 4px;
				padding: 0.22rem 0.48rem;
				background: var(--surface);
				color: var(--accent);
				font: 12px/1.4 "Roboto Mono", "Courier New", monospace;
				cursor: pointer;
			}
			.prose :global(.copy-code:hover),
			.prose :global(.copy-code:focus-visible) {
				color: var(--text);
				border-color: var(--accent);
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{
					variant === 'about' && heroImage && (
						<div class="hero-image">
							<Image width={1020} height={510} src={heroImage} alt="" />
						</div>
					)
				}
				<div class="prose">
					{variant === 'article' && <a class="back-link" href="/blog">← Blog</a>}
					<div class="title">
						<h1>{title}</h1>
						<div class="date">
							{
								variant === 'about' ? (
									<span class="last-updated-on">
										Last updated on{' '}
										<FormattedDate date={updatedDate ?? pubDate} long />
									</span>
								) : (
									<>
										<FormattedDate date={pubDate} long />
										{updatedDate && (
											<>
												<br />
												<span class="last-updated-on">
													Last updated on <FormattedDate date={updatedDate} long />
												</span>
											</>
										)}
									</>
								)
							}
						</div>
						<hr />
					</div>
					{
						variant === 'article' && heroImage && (
							<div class="hero-image">
								<Image width={1020} height={510} src={heroImage} alt={title} />
							</div>
						)
					}
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		<script>
			const codeBlocks = document.querySelectorAll('.prose pre');

			codeBlocks.forEach((pre) => {
				if (pre.parentElement?.classList.contains('code-block')) return;

				const wrapper = document.createElement('div');
				wrapper.className = 'code-block';
				pre.parentNode?.insertBefore(wrapper, pre);
				wrapper.appendChild(pre);

				const button = document.createElement('button');
				button.className = 'copy-code';
				button.type = 'button';
				button.textContent = 'Copy';
				button.setAttribute('aria-label', 'Copy code');
				wrapper.appendChild(button);

				button.addEventListener('click', async () => {
					const code = pre.querySelector('code')?.textContent ?? pre.textContent ?? '';

					try {
						await navigator.clipboard.writeText(code);
						button.textContent = 'Copied';
					} catch {
						button.textContent = 'Failed';
					}

					window.setTimeout(() => {
						button.textContent = 'Copy';
					}, 1600);
				});
			});
		</script>
	</body>
</html>
