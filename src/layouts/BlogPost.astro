---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	/** About page: single “Last updated on …” line like the starter screenshot */
	variant?: 'article' | 'about';
};

const {
	variant = 'article',
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
} = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 560px;
				margin: 0 auto;
			}
			article {
				display: flex;
				flex-direction: column;
				align-items: stretch;
			}
			.hero-image {
				width: 100%;
				margin: 0 0 1.25rem 0;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: auto;
				margin: 0;
				border-radius: 0;
				box-shadow: none;
			}
			.prose {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
				color: var(--text);
				text-align: left;
			}
			.title {
				margin: 0 0 1.35rem 0;
				padding: 0;
				text-align: left;
				line-height: 1.3;
			}
			.title h1 {
				margin: 0 0 1rem 0;
				font-size: 30px;
				font-weight: 700;
				line-height: 1.18;
				color: var(--text);
			}
			.date {
				margin: 0 0 1.25rem 0;
				font-size: 13px;
				line-height: 1.5;
				color: var(--muted);
				font-weight: 400;
			}
			.title hr {
				margin: 0;
				border: none;
				border-top: 1px solid #e5e5e5;
			}
			.last-updated-on {
				font-style: normal;
			}
			.back-link {
				display: inline-block;
				margin: 0 0 1.8rem;
				color: var(--accent);
			}
			.prose :global(p) {
				margin: 0 0 1rem;
				font-size: 16px;
				line-height: 1.55;
			}
			.prose :global(h2) {
				margin: 1.25rem 0 0.25rem;
				font-size: 16px;
				line-height: 1.35;
			}
			.prose :global(img) {
				display: block;
				width: 100%;
				height: auto;
				margin: 1.25rem 0;
				cursor: zoom-in;
			}
			.prose :global(.hero-image img) {
				margin: 0;
				cursor: default;
			}
			.prose :global(.code-block) {
				position: relative;
				display: block;
				width: 100%;
				margin: 0 0 1.35rem;
			}
			.prose :global(.code-block pre) {
				margin: 0;
				padding-top: 2.75rem;
				padding-right: 1rem;
			}
			.prose :global(.code-language) {
				position: absolute;
				top: 0.72rem;
				left: 0.85rem;
				z-index: 1;
				max-width: calc(100% - 6.5rem);
				overflow: hidden;
				color: var(--muted);
				font: 700 11px/1.4 "Roboto Mono", "Courier New", monospace;
				letter-spacing: 0;
				text-overflow: ellipsis;
				text-transform: uppercase;
				white-space: nowrap;
			}
			.prose :global(.copy-code) {
				position: absolute;
				top: 0.65rem;
				right: 0.65rem;
				z-index: 1;
				border: 1px solid var(--code-block-border);
				border-radius: 4px;
				padding: 0.22rem 0.48rem;
				background: var(--surface);
				color: var(--accent);
				font: 600 12px/1.35 Arial, Helvetica, sans-serif;
				cursor: pointer;
			}
			.prose :global(.copy-code:hover),
			.prose :global(.copy-code:focus-visible) {
				color: var(--text);
				border-color: var(--accent);
			}
			.image-lightbox {
				position: fixed;
				inset: 0;
				z-index: 20;
				display: none;
				align-items: center;
				justify-content: center;
				padding: 1.25rem;
				background: rgba(0, 0, 0, 0.84);
			}
			.image-lightbox.is-open {
				display: flex;
			}
			.image-lightbox__image {
				display: block;
				max-width: min(100%, 1120px);
				max-height: calc(100vh - 5rem);
				width: auto;
				height: auto;
				box-shadow: 0 18px 50px rgba(0, 0, 0, 0.35);
			}
			.image-lightbox__close {
				position: fixed;
				top: 1rem;
				right: 1rem;
				width: 2.5rem;
				height: 2.5rem;
				border: 1px solid rgba(255, 255, 255, 0.32);
				border-radius: 4px;
				background: rgba(0, 0, 0, 0.42);
				color: #fff;
				font: 24px/1 Arial, Helvetica, sans-serif;
				cursor: pointer;
			}
			.image-lightbox__close:hover,
			.image-lightbox__close:focus-visible {
				border-color: #fff;
				background: rgba(0, 0, 0, 0.68);
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{
					variant === 'about' && heroImage && (
						<div class="hero-image">
							<Image width={1020} height={510} src={heroImage} alt="" />
						</div>
					)
				}
				<div class="prose">
					{variant === 'article' && <a class="back-link" href="/blog">← Blog</a>}
					<div class="title">
						<h1>{title}</h1>
						<div class="date">
							{
								variant === 'about' ? (
									<span class="last-updated-on">
										Last updated on{' '}
										<FormattedDate date={updatedDate ?? pubDate} long />
									</span>
								) : (
									<>
										<FormattedDate date={pubDate} long />
										{updatedDate && (
											<>
												<br />
												<span class="last-updated-on">
													Last updated on <FormattedDate date={updatedDate} long />
												</span>
											</>
										)}
									</>
								)
							}
						</div>
						<hr />
					</div>
					{
						variant === 'article' && heroImage && (
							<div class="hero-image">
								<Image width={1020} height={510} src={heroImage} alt={title} />
							</div>
						)
					}
					<slot />
				</div>
			</article>
		</main>
		<div class="image-lightbox" aria-hidden="true">
			<button class="image-lightbox__close" type="button" aria-label="Close image">
				×
			</button>
			<img class="image-lightbox__image" src="" alt="" />
		</div>
		<Footer />
		<script>
			const codeBlocks = document.querySelectorAll('.prose pre');
			const languageNames = new Map([
				['astro', 'Astro'],
				['bash', 'Shell'],
				['bal', 'Ballerina'],
				['ballerina', 'Ballerina'],
				['css', 'CSS'],
				['html', 'HTML'],
				['javascript', 'JavaScript'],
				['js', 'JavaScript'],
				['json', 'JSON'],
				['jsx', 'JSX'],
				['md', 'Markdown'],
				['mdx', 'MDX'],
				['shell', 'Shell'],
				['shellscript', 'Shell'],
				['sh', 'Shell'],
				['ts', 'TypeScript'],
				['tsx', 'TSX'],
				['typescript', 'TypeScript'],
				['yaml', 'YAML'],
				['yml', 'YAML'],
				['zsh', 'Shell'],
			]);

			const getLanguage = (pre) => {
				const code = pre.querySelector('code');
				const className = `${pre.className} ${code?.className ?? ''}`;
				const match = className.match(/(?:^|\s)language-([^\s]+)/);
				const language = (pre.dataset.language ?? match?.[1])?.toLowerCase();

				if (!language) return null;

				return languageNames.get(language) ?? language;
			};

			codeBlocks.forEach((pre) => {
				if (pre.parentElement?.classList.contains('code-block')) return;

				const wrapper = document.createElement('div');
				wrapper.className = 'code-block';
				pre.parentNode?.insertBefore(wrapper, pre);
				wrapper.appendChild(pre);

				const language = getLanguage(pre);
				if (language) {
					const label = document.createElement('div');
					label.className = 'code-language';
					label.textContent = language;
					wrapper.appendChild(label);
				}

				const button = document.createElement('button');
				button.className = 'copy-code';
				button.type = 'button';
				button.textContent = 'Copy';
				button.setAttribute('aria-label', 'Copy code');
				wrapper.appendChild(button);

				button.addEventListener('click', async () => {
					const code = pre.querySelector('code')?.textContent ?? pre.textContent ?? '';

					try {
						await navigator.clipboard.writeText(code);
						button.textContent = 'Copied';
					} catch {
						button.textContent = 'Failed';
					}

					window.setTimeout(() => {
						button.textContent = 'Copy';
					}, 1600);
				});
			});

			const lightbox = document.querySelector('.image-lightbox');
			const lightboxImage = lightbox?.querySelector('.image-lightbox__image');
			const lightboxClose = lightbox?.querySelector('.image-lightbox__close');
			const contentImages = [...document.querySelectorAll('.prose img')].filter(
				(image) => !image.closest('.hero-image')
			);

			const closeLightbox = () => {
				if (!(lightbox instanceof HTMLElement) || !(lightboxImage instanceof HTMLImageElement)) {
					return;
				}

				lightbox.classList.remove('is-open');
				lightbox.setAttribute('aria-hidden', 'true');
				lightboxImage.removeAttribute('src');
				lightboxImage.alt = '';
				document.body.style.removeProperty('overflow');
			};

			const openLightbox = (image) => {
				if (!(lightbox instanceof HTMLElement) || !(lightboxImage instanceof HTMLImageElement)) {
					return;
				}

				lightboxImage.src = image.currentSrc || image.src;
				lightboxImage.alt = image.alt;
				lightbox.classList.add('is-open');
				lightbox.setAttribute('aria-hidden', 'false');
				document.body.style.overflow = 'hidden';

				if (lightboxClose instanceof HTMLButtonElement) {
					lightboxClose.focus();
				}
			};

			contentImages.forEach((image) => {
				image.setAttribute('tabindex', '0');
				image.setAttribute('role', 'button');
				image.setAttribute('aria-label', image.alt ? `View image: ${image.alt}` : 'View image');
				image.addEventListener('click', () => openLightbox(image));
				image.addEventListener('keydown', (event) => {
					if (event.key !== 'Enter' && event.key !== ' ') return;

					event.preventDefault();
					openLightbox(image);
				});
			});

			lightboxClose?.addEventListener('click', closeLightbox);
			lightbox?.addEventListener('click', (event) => {
				if (event.target === lightbox) closeLightbox();
			});
			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') closeLightbox();
			});
		</script>
	</body>
</html>
