---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import ProjectImage from "../assets/blog-placeholder-3.jpg";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const projectEntries = await getCollection("projects");
const sortedProjects = [...projectEntries].sort((a, b) => {
  const byFeatured = Number(b.data.featured) - Number(a.data.featured);
  if (byFeatured !== 0) return byFeatured;
  return a.data.order - b.data.order;
});
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Projects | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <h1 class="page-title">projects</h1>
      <p class="page-subtitle">A growing collection of my projects.</p>
      <ul class="project-grid" aria-label="Projects">
        {
          sortedProjects.map((project) => (
            <li class="project-card">
              {project.data.url ? (
                <a
                  class="project-card-link"
                  href={project.data.url}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <img
                    class="project-card-image"
                    src={ProjectImage.src}
                    alt=""
                    loading="lazy"
                  />
                  <div class="project-card-body">
                    <h2 class="project-card-title">{project.data.title}</h2>
                    <p class="project-card-desc" title={project.data.description}>
                      {project.data.description}
                    </p>
                  </div>
                </a>
              ) : (
                <>
                  <img
                    class="project-card-image"
                    src={ProjectImage.src}
                    alt=""
                    loading="lazy"
                  />
                  <div class="project-card-body">
                    <h2 class="project-card-title">{project.data.title}</h2>
                    <p class="project-card-desc" title={project.data.description}>
                      {project.data.description}
                    </p>
                  </div>
                </>
              )}
            </li>
          ))
        }
      </ul>
    </main>
    <Footer />
  </body>
</html>
