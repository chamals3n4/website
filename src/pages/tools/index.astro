---
import BaseHead from '../../components/BaseHead.astro';

const tools = [
	{
		href: '/tools/epf-etf-calculator',
		title: 'EPF / ETF Calculator',
		description: 'See deductions, employer contributions, and take-home salary.',
	},
];
---

<html lang="en">
	<head>
		<BaseHead
			title="Free Online Tools - Chamal Senarathna"
			description="Free online calculators and utilities by Chamal Senarathna, including a Sri Lanka EPF/ETF calculator."
			keywords="Chamal Senarathna tools, free online calculators, EPF ETF calculator, Sri Lanka tools, web utilities"
		/>
		<style>
			:root {
				--accent: #7a1128;
				--accent-dark: #5c0c1e;
				--text: #16181d;
				--muted: #6b7280;
				--border: #e8e8ec;
				--surface: #fff;
				--surface-alt: #faf5f6;
				color-scheme: light;
			}
			:root[data-theme='dark'] {
				--accent: #d15b72;
				--accent-dark: #b8465e;
				--text: #f2f2f2;
				--muted: #9aa3ad;
				--border: #3a3a3a;
				--surface: #1b1b1b;
				--surface-alt: #201619;
				color-scheme: dark;
			}
			body {
				display: block;
				padding: 0;
				background: var(--surface-alt);
				color: var(--text);
			}
			main {
				max-width: 720px;
				margin: 0 auto;
				padding: 2.5rem 1.25rem 5rem;
			}
			a.back {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				margin-bottom: 1.75rem;
				font-size: 13px;
				color: var(--muted);
			}
			a.back:hover {
				color: var(--accent);
			}
			a.back svg {
				width: 15px;
				height: 15px;
			}
			header.page-header {
				margin-bottom: 1.75rem;
			}
			h1 {
				font-size: 26px;
				letter-spacing: -0.01em;
				margin-bottom: 0.35rem;
			}
			.subtitle {
				color: var(--muted);
				font-size: 14px;
				max-width: 60ch;
			}
			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
				gap: 1rem;
			}
			.tool-card {
				display: block;
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 4px;
				box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04);
				padding: 1.5rem;
				color: var(--text);
				transition: border-color 0.15s ease, box-shadow 0.15s ease;
			}
			.tool-card:hover {
				border-color: var(--accent);
				box-shadow: 0 4px 12px rgba(122, 17, 40, 0.12);
				color: var(--text);
			}
			.tool-card h2 {
				font-size: 16px;
				margin-bottom: 0.4rem;
			}
			.tool-card p {
				font-size: 13px;
				color: var(--muted);
				margin: 0;
			}

			.theme-toggle {
				position: fixed;
				right: 18px;
				bottom: 18px;
				z-index: 40;
				width: 42px;
				height: 42px;
				display: inline-flex;
				align-items: center;
				justify-content: center;
				border: 1px solid var(--border);
				border-radius: 50%;
				background: var(--surface);
				color: var(--text);
				box-shadow: 0 10px 28px rgba(0, 0, 0, 0.16);
				cursor: pointer;
			}
			.theme-toggle svg {
				width: 18px;
				height: 18px;
			}
			.theme-toggle .icon-moon {
				display: none;
			}
			:root[data-theme='dark'] .theme-toggle .icon-sun {
				display: none;
			}
			:root[data-theme='dark'] .theme-toggle .icon-moon {
				display: block;
			}
		</style>
	</head>
	<body>
		<main>
			<a class="back" href="/">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
				Back home
			</a>

			<header class="page-header">
				<h1>Tools</h1>
				<p class="subtitle">A collection of small, useful calculators and utilities.</p>
			</header>

			<div class="grid">
				{tools.map((tool) => (
					<a class="tool-card" href={tool.href}>
						<h2>{tool.title}</h2>
						<p>{tool.description}</p>
					</a>
				))}
			</div>
		</main>

		<button class="theme-toggle" type="button" aria-label="Toggle theme" data-theme-toggle>
			<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path></svg>
			<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg>
		</button>

		<script>
			document.querySelector('[data-theme-toggle]')?.addEventListener('click', () => {
				const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
				document.documentElement.dataset.theme = next;
				localStorage.setItem('theme', next);
			});
		</script>
	</body>
</html>
