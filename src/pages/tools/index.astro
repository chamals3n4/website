---
import BaseHead from '../../components/BaseHead.astro';

const tools = [
	{
		href: '/tools/epf-etf-calculator',
		title: 'EPF / ETF Calculator',
		description: 'See deductions, employer contributions, and take-home salary.',
	},
];
---

<html lang="en">
	<head>
		<BaseHead
			title="Free Online Tools - Chamal Senarathna"
			description="Free online calculators and utilities by Chamal Senarathna, including a Sri Lanka EPF/ETF calculator."
			keywords="Chamal Senarathna tools, free online calculators, EPF ETF calculator, Sri Lanka tools, web utilities"
		/>
		<script is:inline>
			document.documentElement.dataset.theme = "light";
		</script>
		<style>
			:root {
				--accent: #7a1128;
				--accent-dark: #5c0c1e;
				--text: #16181d;
				--muted: #6b7280;
				--border: #e8e8ec;
				--surface: #fff;
				--surface-alt: #faf5f6;
				color-scheme: light;
			}
			body {
				display: block;
				padding: 0;
				background: var(--surface-alt);
				color: var(--text);
			}
			main {
				max-width: 720px;
				margin: 0 auto;
				padding: 2.5rem 1.25rem 5rem;
			}
			a.back {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				margin-bottom: 1.75rem;
				font-size: 13px;
				color: var(--muted);
			}
			a.back:hover {
				color: var(--accent);
			}
			a.back svg {
				width: 15px;
				height: 15px;
			}
			header.page-header {
				margin-bottom: 1.75rem;
			}
			h1 {
				font-size: 26px;
				letter-spacing: -0.01em;
				margin-bottom: 0.35rem;
			}
			.subtitle {
				color: var(--muted);
				font-size: 14px;
				max-width: 60ch;
			}
			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
				gap: 1rem;
			}
			.tool-card {
				display: block;
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 4px;
				box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04);
				padding: 1.5rem;
				color: var(--text);
				transition: border-color 0.15s ease, box-shadow 0.15s ease;
			}
			.tool-card:hover {
				border-color: var(--accent);
				box-shadow: 0 4px 12px rgba(122, 17, 40, 0.12);
				color: var(--text);
			}
			.tool-card h2 {
				font-size: 16px;
				margin-bottom: 0.4rem;
			}
			.tool-card p {
				font-size: 13px;
				color: var(--muted);
				margin: 0;
			}
		</style>
	</head>
	<body>
		<main>
			<a class="back" href="/">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
				Back home
			</a>

			<header class="page-header">
				<h1>Tools</h1>
				<p class="subtitle">A collection of small, useful calculators and utilities.</p>
			</header>

			<div class="grid">
				{tools.map((tool) => (
					<a class="tool-card" href={tool.href}>
						<h2>{tool.title}</h2>
						<p>{tool.description}</p>
					</a>
				))}
			</div>
		</main>
	</body>
</html>
