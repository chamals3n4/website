---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { getCollection } from "astro:content";

const projectEntries = await getCollection("projects");
const sortedProjects = [...projectEntries].sort((a, b) => {
  const byFeatured = Number(b.data.featured) - Number(a.data.featured);
  if (byFeatured !== 0) return byFeatured;
  return a.data.order - b.data.order;
});
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <p>
        I build things on the web. Some work, some break, all of them teach me
        something.
      </p>
      <p>
        I’m currently studying software engineering and working on different
        kinds of applications, improving step by step. I also write down
        thoughts here , things I notice, things I feel like sharing,
        and things I’m still figuring out.
      </p>
      <p>
        There’s this line from Silicon Valley about “making the world a better
        place with software”. I like that idea, and it’s something I keep in
        mind when I build.
      </p>
      <p>
        This space is a collection of my work, thoughts, and progress over time.
      </p>

      <section class="home-projects" aria-labelledby="projects-heading">
        <h2 id="projects-heading" class="home-projects-title">
          Things I’ve Shipped
        </h2>

        {
          sortedProjects.length > 0 && (
            <ul class="project-grid">
              {sortedProjects.map((project) => (
                <li class="project-card">
                  {project.data.url ? (
                    <a
                      class="project-card-link"
                      href={project.data.url}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      <h3 class="project-card-title">{project.data.title}</h3>
                      <p
                        class="project-card-desc"
                        title={project.data.description}
                      >
                        {project.data.description}
                      </p>
                    </a>
                  ) : (
                    <>
                      <h3 class="project-card-title">{project.data.title}</h3>
                      <p
                        class="project-card-desc"
                        title={project.data.description}
                      >
                        {project.data.description}
                      </p>
                    </>
                  )}
                </li>
              ))}
            </ul>
          )
        }
      </section>
    </main>
    <Footer />
  </body>
</html>
