---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 100%;
				max-width: var(--page-width);
				margin-top: 1.25rem;
			}
			.blog-search {
				width: 100%;
				height: 42px;
				margin: 0 0 1rem;
				padding: 0 14px;
				border: 1px solid var(--border);
				border-radius: 4px;
				background: var(--surface);
				color: var(--text);
				font: inherit;
				font-size: 14px;
				outline: none;
			}
			.blog-search:focus {
				border-color: var(--accent);
			}
			.blog-search::placeholder {
				color: var(--muted);
			}
			.post-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-row {
				margin: 0;
				border: 1px solid var(--border);
				background: var(--surface);
				line-height: 1.45;
				transition: border-color 500ms ease;
				cursor: pointer;
			}
			.post-row:hover {
				border-color: var(--accent);
			}
			.post-date {
				margin: 6px 0 0;
				font-weight: 400;
				color: var(--muted);
				font-size: 13px;
			}
			.post-title-link {
				display: block;
				padding: 20px 24px;
				color: inherit;
				text-decoration: none;
			}
			.post-title-link:hover {
				color: inherit;
			}
			.post-title-link:visited {
				color: inherit;
			}
			.post-title {
				display: inline-block;
				color: var(--accent);
				font-size: 16px;
				font-weight: 700;
				line-height: 1.35;
			}
			.post-description {
				margin: 3px 0 0;
				font-size: 14px;
				color: var(--text);
			}
			.no-results {
				display: none;
				margin: 1rem 0 0;
				color: var(--muted);
				font-size: 14px;
			}
			.no-results.is-visible {
				display: block;
			}
			@media (max-width: 720px) {
				.post-title-link {
					padding: 18px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<input
				class="blog-search"
				type="search"
				placeholder="Search posts..."
				aria-label="Search blog posts"
				data-blog-search
			/>
			<ul class="post-list">
				{
					posts.map((post) => (
						<li
							class="post-row"
							data-search-text={`${post.data.title} ${post.data.description} ${post.data.pubDate.toDateString()}`.toLowerCase()}
						>
							<a class="post-title-link" href={`/blog/${post.id}/`}>
								<span class="post-title">{post.data.title}</span>
								<p class="post-description">{post.data.description}</p>
								<div class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</div>
							</a>
						</li>
					))
				}
			</ul>
			<p class="no-results" data-blog-empty>No posts found.</p>
		</main>
		<Footer />
		<script>
			const blogSearch = document.querySelector('[data-blog-search]');
			const postRows = Array.from(document.querySelectorAll('.post-row'));
			const emptyState = document.querySelector('[data-blog-empty]');

			if (blogSearch instanceof HTMLInputElement) {
				blogSearch.addEventListener('input', () => {
					const query = blogSearch.value.trim().toLowerCase();
					let visibleCount = 0;

					postRows.forEach((row) => {
						if (!(row instanceof HTMLElement)) return;

						const matches = row.dataset.searchText?.includes(query) ?? false;
						row.hidden = !matches;
						if (matches) visibleCount += 1;
					});

					emptyState?.classList.toggle('is-visible', visibleCount === 0);
				});
			}
		</script>
	</body>
</html>
