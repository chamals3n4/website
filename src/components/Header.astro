---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
---

<div class="header-root" {...Astro.props}>
<header class="site-header">
  <div class="nav-bar">
    <h2 class="site-title"><a href="/">{SITE_TITLE}</a></h2>
    <nav class="site-nav" aria-label="Main navigation" data-site-nav>
      <HeaderLink href="/">About</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/projects">Projects</HeaderLink>
      <HeaderLink href="/tools">Tools</HeaderLink>
    </nav>
    <button class="site-search" type="button" aria-label="Open search" data-search-open>
      <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
      <span class="site-search-placeholder">Search...</span>
      <kbd>⌘K</kbd>
    </button>
    <button class="theme-button" type="button" aria-label="Toggle theme" data-theme-toggle>
      ◔
    </button>
    <button class="menu-toggle" type="button" aria-label="Toggle menu" aria-expanded="false" data-menu-toggle>
      <svg class="icon-menu" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16"></path><path d="M4 12h16"></path><path d="M4 18h16"></path></svg>
      <svg class="icon-close" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
    </button>
  </div>
</header>
<div class="search-overlay" data-search-overlay aria-hidden="true">
  <div class="search-dialog" role="dialog" aria-modal="true" aria-label="Search">
    <input
      class="search-dialog-input"
      type="search"
      placeholder="Search or jump to..."
      aria-label="Search or jump to"
      data-search-input
    />
    <div class="search-section-label">Navigation</div>
    <nav class="search-results" aria-label="Search navigation">
      <a class="search-result is-active" href="/">About</a>
      <a class="search-result" href="/blog">Blog</a>
      <a class="search-result" href="/projects">Projects</a>
      <a class="search-result" href="/tools">Tools</a>
    </nav>
    <div class="search-help" aria-hidden="true">
      <span><kbd>↵</kbd> to select</span>
      <span><kbd>↓</kbd><kbd>↑</kbd> to navigate</span>
      <span><kbd>esc</kbd> to close</span>
    </div>
  </div>
</div>
<button class="scroll-top" type="button" aria-label="Back to top" data-scroll-top>
  <svg aria-hidden="true" viewBox="0 0 24 24">
    <path d="M12 5 5.5 11.5l1.4 1.4 4.1-4.1V20h2V8.8l4.1 4.1 1.4-1.4L12 5Z" />
  </svg>
</button>
</div>
<script>
  const updateActiveNavLink = () => {
    const pathname = window.location.pathname.replace(import.meta.env.BASE_URL, "");
    const subpath = pathname.match(/[^\/]+/g);

    document.querySelectorAll(".site-nav a").forEach((link) => {
      const href = link.getAttribute("href");
      const isActive = href === pathname || href === "/" + (subpath?.[0] || "");
      link.classList.toggle("active", Boolean(isActive));
    });
  };

  document.addEventListener("astro:page-load", updateActiveNavLink);

  const themeToggle = document.querySelector("[data-theme-toggle]");
  const searchOpen = document.querySelector("[data-search-open]");
  const searchOverlay = document.querySelector("[data-search-overlay]");
  const searchInput = document.querySelector("[data-search-input]");
  const searchResults = Array.from(document.querySelectorAll(".search-result"));
  const scrollTopButton = document.querySelector("[data-scroll-top]");
  const menuToggle = document.querySelector("[data-menu-toggle]");
  const siteNav = document.querySelector("[data-site-nav]");

  const closeMenu = () => {
    siteNav?.classList.remove("is-open");
    menuToggle?.setAttribute("aria-expanded", "false");
  };

  menuToggle?.addEventListener("click", () => {
    const isOpen = siteNav?.classList.toggle("is-open");
    menuToggle.setAttribute("aria-expanded", String(Boolean(isOpen)));
  });

  siteNav?.addEventListener("click", (event) => {
    if (event.target instanceof HTMLAnchorElement) closeMenu();
  });

  document.addEventListener("astro:page-load", closeMenu);

  themeToggle?.addEventListener("click", () => {
    const nextTheme =
      document.documentElement.dataset.theme === "dark" ? "light" : "dark";

    document.documentElement.dataset.theme = nextTheme;
    localStorage.setItem("theme", nextTheme);
  });

  let activeResultIndex = 0;

  const updateActiveResult = () => {
    searchResults.forEach((result, index) => {
      result.classList.toggle("is-active", index === activeResultIndex);
    });
  };

  const openSearch = () => {
    searchOverlay?.classList.add("is-open");
    searchOverlay?.setAttribute("aria-hidden", "false");
    document.body.classList.add("search-open");
    activeResultIndex = 0;
    updateActiveResult();
    window.setTimeout(() => searchInput?.focus(), 80);
  };

  const closeSearch = () => {
    searchOverlay?.classList.remove("is-open");
    searchOverlay?.setAttribute("aria-hidden", "true");
    document.body.classList.remove("search-open");
    searchInput.value = "";
  };

  searchOpen?.addEventListener("click", openSearch);

  searchOverlay?.addEventListener("click", (event) => {
    if (event.target === searchOverlay) closeSearch();
  });

  document.addEventListener("click", (event) => {
    if (!siteNav?.classList.contains("is-open")) return;
    if (event.target instanceof Node && (siteNav.contains(event.target) || menuToggle?.contains(event.target))) return;
    closeMenu();
  });

  document.addEventListener("keydown", (event) => {
    const isSearchShortcut = (event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "k";

    if (isSearchShortcut) {
      event.preventDefault();
      openSearch();
      return;
    }

    if (event.key === "Escape") closeMenu();

    if (!searchOverlay?.classList.contains("is-open")) return;

    if (event.key === "Escape") {
      closeSearch();
      return;
    }

    if (event.key === "ArrowDown") {
      event.preventDefault();
      activeResultIndex = (activeResultIndex + 1) % searchResults.length;
      updateActiveResult();
      return;
    }

    if (event.key === "ArrowUp") {
      event.preventDefault();
      activeResultIndex =
        (activeResultIndex - 1 + searchResults.length) % searchResults.length;
      updateActiveResult();
      return;
    }

    if (event.key === "Enter") {
      event.preventDefault();
      searchResults[activeResultIndex]?.click();
    }
  });

  const updateScrollTopButton = () => {
    const scrollPosition = window.scrollY + window.innerHeight;
    const nearBottom = document.documentElement.scrollHeight - scrollPosition < 220;
    scrollTopButton?.classList.toggle("is-visible", nearBottom && window.scrollY > 240);
  };

  scrollTopButton?.addEventListener("click", () => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });

  updateScrollTopButton();
  document.addEventListener("scroll", updateScrollTopButton, { passive: true });
  window.addEventListener("resize", updateScrollTopButton);
</script>
<style is:global>
  .site-header {
    width: 100vw;
    margin: 0 0 2.35rem;
    margin-left: calc(50% - 50vw);
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }
  .nav-bar {
    box-sizing: border-box;
    max-width: 808px;
    height: 65px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1.55rem;
  }
  .site-title {
    flex: 0 0 auto;
    margin: 0;
    line-height: 1.2;
    font-size: 16px;
    font-weight: 700;
  }
  .site-title a {
    color: inherit;
    text-decoration: none;
  }
  .site-nav {
    display: flex;
    align-items: center;
    gap: 1.35rem;
    font-size: 13px;
    white-space: nowrap;
  }
  .site-nav a {
    color: var(--text);
    text-decoration: none;
    cursor: pointer;
  }
  .site-nav a.active {
    color: var(--accent);
    font-weight: 700;
  }
  .theme-button {
    border: 0;
    padding: 0;
    background: transparent;
    font: inherit;
    color: var(--text);
    cursor: pointer;
    appearance: none;
  }
  .site-search {
    flex: 0 0 190px;
    height: 30px;
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    box-sizing: border-box;
    padding: 0 0.45rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--surface);
    color: #64748b;
    font-size: 12px;
    cursor: pointer;
    appearance: none;
  }
  .site-search span {
    line-height: 1;
  }
  .site-search svg {
    flex: 0 0 auto;
    width: 14px;
    height: 14px;
  }
  .site-search-placeholder {
    width: 100%;
    min-width: 0;
    text-align: left;
    color: var(--muted);
  }
  .site-search kbd {
    flex: 0 0 auto;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.05rem 0.25rem;
    background: var(--code-bg);
    color: var(--muted);
    font: inherit;
  }
  .theme-button {
    flex: 0 0 auto;
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    line-height: 1;
  }
  .search-open {
    overflow: hidden;
  }
  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 38px 1rem;
    background: rgba(0, 0, 0, 0);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 220ms ease,
      background-color 220ms ease;
  }
  .search-overlay.is-open {
    background: rgba(0, 0, 0, 0.66);
    opacity: 1;
    pointer-events: auto;
  }
  .search-dialog {
    width: min(576px, calc(100vw - 2rem));
    max-height: min(80vh, 380px);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 4px;
    background: #202529;
    color: #e7edf3;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.45);
    transform: translateY(-10px) scale(0.98);
    transition: transform 220ms ease;
  }
  .search-overlay.is-open .search-dialog {
    transform: translateY(0) scale(1);
  }
  .search-dialog-input {
    width: 100%;
    height: 60px;
    border: 0;
    border-bottom: 1px solid #343b40;
    outline: 0;
    padding: 0 18px;
    background: #202529;
    color: #e7edf3;
    font: inherit;
    font-size: 18px;
  }
  .search-dialog-input::placeholder {
    color: #a8b1bb;
  }
  .search-section-label {
    padding: 10px 14px 6px;
    color: #9aa4ad;
    font-size: 12px;
  }
  .search-results {
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    min-height: 0;
  }
  .search-result {
    display: block;
    padding: 12px 16px;
    color: #f4f7f9;
    text-decoration: none;
    cursor: pointer;
  }
  .search-result:hover,
  .search-result.is-active {
    color: #fff;
    background: #2f9db7;
  }
  .search-help {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    padding: 10px 14px;
    border-top: 1px solid #343b40;
    color: #a8b1bb;
    font-size: 12px;
  }
  .search-help kbd {
    display: inline-block;
    min-width: 22px;
    margin-right: 0.25rem;
    padding: 2px 6px;
    border-radius: 4px;
    background: #3a4148;
    color: #c7d0d8;
    font: inherit;
    text-align: center;
  }
  .scroll-top {
    position: fixed;
    right: 18px;
    bottom: 62px;
    z-index: 40;
    width: 42px;
    height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.22);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px) scale(0.96);
    transition:
      opacity 180ms ease,
      transform 180ms ease;
    appearance: none;
  }
  .scroll-top.is-visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }
  .scroll-top:hover,
  .scroll-top:focus-visible {
    transform: translateY(-2px) scale(1);
  }
  .scroll-top svg {
    width: 21px;
    height: 21px;
    display: block;
    fill: currentColor;
  }
  .menu-toggle {
    display: none;
    flex: 0 0 auto;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    border: 0;
    padding: 0;
    background: transparent;
    color: var(--text);
    cursor: pointer;
    appearance: none;
  }
  .menu-toggle svg {
    width: 22px;
    height: 22px;
  }
  .menu-toggle .icon-close {
    display: none;
  }
  .menu-toggle[aria-expanded="true"] .icon-menu {
    display: none;
  }
  .menu-toggle[aria-expanded="true"] .icon-close {
    display: block;
  }
  @media (max-width: 900px) {
    .nav-bar {
      max-width: none;
      padding: 0 1rem;
      gap: 1rem;
    }
    .site-nav {
      gap: 0.9rem;
      overflow-x: auto;
    }
    .site-search {
      flex: 0 0 auto;
      width: 40px;
      height: 40px;
      padding: 0;
      justify-content: center;
    }
    .site-search-placeholder,
    .site-search kbd {
      display: none;
    }
    .scroll-top {
      right: 14px;
      bottom: 58px;
      width: 40px;
      height: 40px;
    }
  }
  @media (max-width: 640px) {
    .nav-bar {
      position: relative;
    }
    .menu-toggle {
      display: inline-flex;
    }
    .site-nav {
      position: absolute;
      top: calc(100% + 1px);
      left: 0;
      right: 0;
      z-index: 90;
      display: none;
      flex-direction: column;
      align-items: stretch;
      gap: 2px;
      overflow-x: visible;
      padding: 0.6rem;
      border-bottom: 1px solid var(--border);
      background: var(--surface);
      box-shadow: 0 16px 32px rgba(0, 0, 0, 0.18);
    }
    .site-nav.is-open {
      display: flex;
    }
    .site-nav :global(a) {
      width: 100%;
      border-radius: 4px;
      padding: 0.85rem 0.9rem;
      font-size: 14px;
      font-weight: 600;
    }
    .site-nav :global(a.active) {
      background: var(--surface-alt, var(--code-bg));
    }
    .site-nav :global(a:hover) {
      background: var(--code-bg);
    }
  }
  @media (max-width: 420px) {
    .nav-bar {
      gap: 0.6rem;
    }
    .site-title {
      flex: 1 1 auto;
      min-width: 0;
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
      font-size: 15px;
    }
  }
</style>
